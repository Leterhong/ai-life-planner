# Seed Evolving API Configuration
SEED_API_KEY=your-seed-api-key-here
SEED_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEED_MODEL=doubao-seed-evolving

# Application Configuration
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Database Configuration
DATABASE_URL=sqlite+aiosqlite:///./data/ai_life_planner.db

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
VECTOR_DB_PATH=./data/faiss_index
